# MongoDB Connection URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT Secret - use a long random string (min 32 chars)
JWT_SECRET=replace_with_a_long_random_secret_string_here

# Server port
PORT=1783

# Frontend origins allowed to connect (comma-separated for multiple)
ALLOWED_ORIGINS=http://localhost:6464,http://localhost:6463

# Node environment: development | production
NODE_ENV=development
